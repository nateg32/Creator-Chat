# Apify API Token
APIFY_TOKEN=your_apify_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_NAME=rag_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Transcription (set to "true" to enable OpenAI Whisper transcription fallback)
TRANSCRIBE_ON_INGEST=false
