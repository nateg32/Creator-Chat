# Apify API Token
APIFY_TOKEN=your_apify_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# Chat delivery provider. Gemini is the default for transcript-heavy creator chat.
# Set CHAT_PROVIDER=openai to retain the existing OpenAI-compatible chat path.
CHAT_PROVIDER=gemini

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_ANALYSIS_MODEL=gemini-2.5-pro
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_CACHE_LOOKUP_MODEL=gemini-3-pro-preview
GEMINI_CACHE_ROUTER_MODEL=gemini-3-flash-preview
GEMINI_SAFETY_THRESHOLD=BLOCK_MEDIUM_AND_ABOVE
GEMINI_DYNAMIC_RAG_ENABLED=true

# xAI chat/completions (optional)
# Use this if you want Grok for chat while keeping OpenAI for embeddings/transcription.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Optional explicit overrides for features that still rely on OpenAI-compatible embeddings/audio
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_BASE_URL=

# Optional model overrides — must be REAL OpenAI model IDs.
# Recommended Creator Bot stack:
# - Persona analysis / fingerprint creation: GPT-5
# - Live persona chat: GPT-5 mini
# - Routing / guardrails / lightweight classification: GPT-5 nano
MODEL_CLASSIFICATION=gpt-5-nano
MODEL_MEMORY=gpt-5-nano
MODEL_VERIFY=gpt-5-nano
MODEL_SYNTHESIS=gpt-5-mini
MODEL_MAIN_REPLY=gpt-5-mini
MODEL_PERSONA_ANALYSIS=gpt-5
MODEL_PERSONA_ANALYSIS_ADVANCED=gpt-5
MODEL_FALLBACK_FAST=gpt-5-nano
MODEL_FALLBACK_SMART=gpt-5-mini

# Keep Gemini for web search / grounded research.
LIVE_SEARCH_PROVIDER=gemini
GEMINI_GROUNDING_MODEL=gemini-2.5-flash
GEMINI_CONTEXT_CACHE_ENABLED=true
GEMINI_CONTEXT_CACHE_TTL_SECONDS=86400
GEMINI_CONTEXT_CACHE_MAX_CHARS=800000

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_NAME=rag_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Transcription (set to "true" to enable OpenAI Whisper transcription fallback)
TRANSCRIBE_ON_INGEST=false

# Frontend origin(s) for CORS (comma-separated for multiple domains)
# Example: CORS_ORIGINS=https://anti-gravity-bice.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=

# Optional frontend URL list. Accepts a single URL or comma-separated URLs.
FRONTEND_URL=

# Optional alias for multiple frontend URLs if you prefer a dedicated variable.
FRONTEND_URLS=
