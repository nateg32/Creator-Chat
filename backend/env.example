# Apify API Token
APIFY_TOKEN=your_apify_token_here

# OpenAI-compatible API key, still used by embeddings/transcription paths.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# Chat delivery provider is permanently Gemini for creator replies.
CHAT_PROVIDER=gemini

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_ANALYSIS_MODEL=gemini-3-pro-preview
GEMINI_CHAT_MODEL=gemini-3-flash-preview
GEMINI_VISION_MODEL=gemini-3-flash-preview
GEMINI_VISION_TIMEOUT_SECONDS=12.0
GEMINI_VISION_MAX_INLINE_BYTES=8000000
GEMINI_VISION_MEDIA_RESOLUTION=MEDIA_RESOLUTION_HIGH
GEMINI_FACT_SYNTHESIS_MODEL=gemini-3-pro-preview
GEMINI_CACHE_LOOKUP_MODEL=gemini-3-pro-preview
GEMINI_CACHE_ROUTER_MODEL=gemini-3-flash-preview
GEMINI_SAFETY_THRESHOLD=BLOCK_ONLY_HIGH
GEMINI_DYNAMIC_RAG_ENABLED=true
GEMINI_FACT_SYNTHESIS_ENABLED=true
AGENTIC_PARALLEL_RETRIEVAL_ENABLED=true
AGENTIC_SEARCH_TIMEOUT_SECONDS=1.2
# Gemini intent routing is required for chat turns.
SMART_INTENT_ROUTER_TIMEOUT_SECONDS=3.5
SMART_INTENT_ROUTER_JOIN_TIMEOUT_SECONDS=3.5
SMART_INTENT_ROUTER_MODEL=gemini-3-flash-preview

# xAI credentials are not used for creator chat replies.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Optional explicit overrides for features that still rely on OpenAI-compatible embeddings/audio
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_BASE_URL=

# Optional model overrides must be Gemini model IDs. Non-Gemini values are ignored.
# Recommended Creator Chat stack:
# - Persona analysis / fingerprint creation: Gemini Pro
# - Live persona chat: Gemini Flash
# - Routing / guardrails / lightweight classification: Gemini Flash
MODEL_CLASSIFICATION=gemini-3-flash-preview
MODEL_MEMORY=gemini-3-flash-preview
MODEL_VERIFY=gemini-3-pro-preview
MODEL_SYNTHESIS=gemini-3-flash-preview
MODEL_MAIN_REPLY=gemini-3-flash-preview
MODEL_FAST_REPLY=gemini-3-flash-preview
MODEL_PERSONA_ANALYSIS=gemini-3-pro-preview
MODEL_PERSONA_ANALYSIS_ADVANCED=gemini-3-pro-preview
MODEL_FALLBACK_FAST=gemini-3-flash-preview
MODEL_FALLBACK_SMART=gemini-3-pro-preview

# Keep Gemini for web search / grounded research, or set LIVE_SEARCH_PROVIDER=brave/exa with an API key.
LIVE_SEARCH_PROVIDER=gemini
GEMINI_GROUNDING_MODEL=gemini-2.5-flash
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=
GEMINI_CONTEXT_CACHE_ENABLED=true
GEMINI_CONTEXT_CACHE_TTL_SECONDS=86400
GEMINI_CONTEXT_CACHE_MAX_CHARS=800000

# Short-term per-thread evidence cache. In production, set this to the internal
# Render Key Value connection string (usually provided as REDIS_URL).
THREAD_CONTEXT_CACHE_ENABLED=true
THREAD_CONTEXT_CACHE_TTL_SECONDS=900
THREAD_CONTEXT_CACHE_MAX_ENTRIES=4
THREAD_CONTEXT_CACHE_REDIS_URL=

# Database Configuration
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=creator_chat
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# Auth / session security
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Transcription
# Apify only scrapes source metadata/items. Whisper owns raw transcripts; AssemblyAI enriches and creates SRT/VTT captions.
TRANSCRIBE_ON_INGEST=true
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_TRANSCRIPT_TIMEOUT_SECONDS=180
ASSEMBLYAI_ENRICHMENT_ENABLED=true
ASSEMBLYAI_CAPTIONS_ENABLED=true
ASSEMBLYAI_CHARS_PER_CAPTION=42

# Render worker queue tuning. Keep worker DB pools small if you scale worker instances.
SYSTEM_JOB_STALE_AFTER_MINUTES=45
SYSTEM_JOB_MAX_RETRIES=2
EMBED_BATCH_SIZE=96
TRANSCRIPT_CONCURRENCY=2
YOUTUBE_TRANSCRIPT_CONCURRENCY=4

# Frontend origin(s) for CORS (comma-separated for multiple domains)
# Example: CORS_ORIGINS=https://your-frontend.example.com,https://your-custom-domain.com
CORS_ORIGINS=

# Optional frontend URL list. Accepts a single URL or comma-separated URLs.
FRONTEND_URL=

# Optional alias for multiple frontend URLs if you prefer a dedicated variable.
FRONTEND_URLS=

# Open-source scrape limits
SCRAPE_MAX_PLATFORMS_PER_SEARCH=8
SCRAPE_MAX_ITEMS_PER_PLATFORM=25000
SCRAPE_MAX_ITEMS_PER_SEARCH=25000
SCRAPE_MAX_CREATORS=250
SCRAPE_MONTHLY_ITEM_ALLOWANCE=25000
